# syntax=docker/dockerfile:1

# -- Stage 0: Base ----------------------------------------------------
FROM node:22-bookworm-slim AS base
RUN corepack enable
WORKDIR /app

# -- Stage 1: Prune monorepo for agent --------------------------------
FROM base AS pruner
RUN npm i -g turbo@^2
COPY . .
RUN turbo prune @chq/agent --docker

# -- Stage 2: Install dependencies ------------------------------------
FROM base AS deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ && rm -rf /var/lib/apt/lists/*

COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=pruner /app/out/pnpm-workspace.yaml ./pnpm-workspace.yaml

RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile

# -- Stage 3: Build agent ---------------------------------------------
FROM deps AS builder
COPY --from=pruner /app/out/full/ .
COPY turbo.json turbo.json
RUN pnpm turbo build --filter=@chq/agent...

# -- Stage 4: Production dependencies ---------------------------------
FROM base AS prod-deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ && rm -rf /var/lib/apt/lists/*

COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=pruner /app/out/pnpm-workspace.yaml ./pnpm-workspace.yaml

RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --prod

# -- Stage 5: Runtime -------------------------------------------------
FROM node:22-bookworm-slim AS runtime
RUN corepack enable && \
    apt-get update && apt-get install -y --no-install-recommends \
    git && rm -rf /var/lib/apt/lists/*
WORKDIR /app

RUN groupadd -g 1000 chq && useradd -u 1000 -g chq -m chq

ENV NODE_ENV=production

COPY --from=prod-deps /app/node_modules ./node_modules
RUN --mount=from=prod-deps,source=/app/packages,target=/tmp/pkg \
    mkdir -p ./packages/shared ./packages/agent && \
    if [ -d /tmp/pkg/shared/node_modules ]; then cp -a /tmp/pkg/shared/node_modules ./packages/shared/node_modules; fi && \
    if [ -d /tmp/pkg/agent/node_modules ]; then cp -a /tmp/pkg/agent/node_modules ./packages/agent/node_modules; fi

COPY --from=builder /app/packages/shared/dist ./packages/shared/dist
COPY --from=builder /app/packages/shared/package.json ./packages/shared/package.json
COPY --from=builder /app/packages/agent/dist ./packages/agent/dist
COPY --from=builder /app/packages/agent/package.json ./packages/agent/package.json
COPY --from=builder /app/package.json ./package.json

RUN mkdir -p /workspace && chown 1000:1000 /workspace

USER 1000:1000

CMD ["node", "packages/agent/dist/cli.js", "agent", "start"]
