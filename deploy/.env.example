# Port the hub is accessible on (host side)
CHQ_HUB_PORT=7700

# Log level: debug, info, warn, error
CHQ_HUB_LOGLEVEL=info

# Shared secret for agent authentication (set this to something strong)
CHQ_AGENT_TOKEN=change-me-to-a-strong-secret

# Anthropic API key (passed to spawned agent containers)
# ANTHROPIC_API_KEY=sk-ant-...

# Path to claude CLI binary on the Docker host (bind-mounted into agent containers)
# CHQ_HUB_CLAUDE_BINARY_HOST_PATH=/usr/local/bin/claude

# Agent container image
# CHQ_HUB_AGENT_IMAGE=chq-agent:local
