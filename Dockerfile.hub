# syntax=docker/dockerfile:1

# ── Stage 0: Base ──────────────────────────────────────────────
FROM node:22-bookworm-slim AS base
RUN corepack enable
WORKDIR /app

# ── Stage 1: Prune monorepo for hub + dashboard ─────────────
FROM base AS pruner
RUN npm i -g turbo@^2
COPY . .
RUN turbo prune @chq/hub @chq/dashboard --docker

# ── Stage 2: Install dependencies ─────────────────────────────
FROM base AS deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ && rm -rf /var/lib/apt/lists/*

COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=pruner /app/out/pnpm-workspace.yaml ./pnpm-workspace.yaml

RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile

# ── Stage 3: Build hub + dashboard ────────────────────────────
FROM deps AS builder
COPY --from=pruner /app/out/full/ .
COPY turbo.json turbo.json
RUN pnpm turbo build --filter=@chq/hub... --filter=@chq/dashboard...

# ── Stage 4: Production dependencies (hub only) ──────────────
FROM base AS prod-deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ && rm -rf /var/lib/apt/lists/*

COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=pruner /app/out/pnpm-workspace.yaml ./pnpm-workspace.yaml

RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --prod

# ── Stage 5: Runtime ──────────────────────────────────────────
FROM node:22-bookworm-slim AS runtime
RUN corepack enable
WORKDIR /app

ENV NODE_ENV=production
ENV NODE_OPTIONS="--max-old-space-size=384"

COPY --from=prod-deps /app/node_modules ./node_modules
RUN --mount=from=prod-deps,source=/app/packages,target=/tmp/pkg \
    if [ -d /tmp/pkg/shared/node_modules ]; then cp -a /tmp/pkg/shared/node_modules ./packages/shared/node_modules; fi && \
    if [ -d /tmp/pkg/hub/node_modules ]; then cp -a /tmp/pkg/hub/node_modules ./packages/hub/node_modules; fi

COPY --from=builder /app/packages/shared/dist ./packages/shared/dist
COPY --from=builder /app/packages/shared/package.json ./packages/shared/package.json
COPY --from=builder /app/packages/hub/dist ./packages/hub/dist
COPY --from=builder /app/packages/hub/package.json ./packages/hub/package.json
COPY --from=builder /app/package.json ./package.json

# Bundle dashboard static files into the image
COPY --from=builder /app/packages/dashboard/.output/public ./dashboard-static

ENV CHQ_HUB_DASHBOARDSTATICPATH=/app/dashboard-static

RUN mkdir -p /app/data/db /app/data/recordings

EXPOSE 7700

HEALTHCHECK --interval=10s --timeout=5s --retries=3 --start-period=15s \
  CMD node -e "fetch('http://localhost:7700/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["node", "packages/hub/dist/index.js"]
