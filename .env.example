# Hub configuration
CHQ_HUB_PORT=7700
CHQ_HUB_LOGLEVEL=info

# Anthropic API key (passed to spawned agent containers)
# ANTHROPIC_API_KEY=sk-ant-...

# Path to claude CLI binary on the Docker host (bind-mounted into agent containers)
# CHQ_HUB_CLAUDE_BINARY_HOST_PATH=/usr/local/bin/claude

# Tailscale (optional, for sidecar mode)
# TS_AUTHKEY=tskey-auth-xxxxx
